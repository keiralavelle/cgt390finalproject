// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id            String         @id @default(uuid())
  name          String?
  email         String         @unique
  password      String?
  meals         Meal[]
  groceries     GroceryItem[]
  calendarMeals CalendarMeal[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
}

model Meal {
  id           String   @id @default(uuid())
  title        String
  description  String?
  ingredients  String[]
  instructions String[]
  isFavorite   Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  calendarMeals CalendarMeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isFavorite])
}

model GroceryItem {
  id       String  @id @default(uuid())
  name     String
  quantity String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CalendarMeal {
  id String @id @default(uuid())

  weekStart DateTime
  day       WeekDay
  slot      MealSlot

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart, day, slot])
  @@index([userId, weekStart])
  @@index([mealId])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}
